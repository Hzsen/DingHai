# Optional. The default uses the repository-local data directory.
# QUANT_AGENT_PROJECT_ROOT=/absolute/path/to/RAG/quant-analyst-rag-agent

# Optional external LLM providers.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Kimi API is billed separately from Kimi Allegretto membership.
# Create the key in the Kimi API console and keep it only in your local .env.
# MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.6
