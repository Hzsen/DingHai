// ============================================================
// Chanlun_DH.pine — 缠论结构工程版 v0.6-phase1-ma
// Pine Script v6
//
// 规范：Chanlun_requirement.md v0.2，第 14–17、21 节
// 当前范围：
//   Phase 0  工程骨架与诊断
//   Phase 1A 收盘后包含处理 / sealed merged bar
//   Phase 1B detected fractal / 顶底分型标记
//   Context  日线 5 SMA / 10 SMA（缠论“吻”辅助，暂不参与分型过滤）
//
// 故意未实现：笔、tentative 笔、线段、中枢、背驰、多级别。
// 主要验收周期：日 K。其他标准 OHLC 周期允许运行，但不属于本阶段重点。
// ============================================================

//@version=6
indicator("缠论 DH — Phase 1 分型", overlay=true,
     max_lines_count=50, max_labels_count=500, max_boxes_count=10)

// ============================================================
// SECTION 0 — 输入、常量与诊断配置
// ============================================================

const int DIR_UNKNOWN = 0
const int DIR_UP      = 1
const int DIR_DOWN    = -1
const int FRAC_TOP    = 1
const int FRAC_BOTTOM = -1

const string GRP_MERGED = "1. 包含处理"
const string GRP_FRAC   = "2. 分型"
const string GRP_TREND  = "3. 日线交易均线"
const string GRP_DEBUG  = "4. 诊断"

int maxStoredMerged = input.int(5000, "最多保存 sealed 合成 K 线", minval=100, maxval=20000, group=GRP_MERGED)
int maxStoredFractal = input.int(2500, "最多保存 detected fractal", minval=100, maxval=10000, group=GRP_FRAC)
int maxVisibleFractal = input.int(120, "最多显示分型标记", minval=10, maxval=300, group=GRP_FRAC)
string fractalMode = input.string("LOOSE", "分型模式", options=["LOOSE", "STRICT"], group=GRP_FRAC)
bool showFractals = input.bool(true, "显示顶底分型", group=GRP_FRAC)
color topColor = input.color(color.new(color.red, 0), "顶分型颜色", group=GRP_FRAC)
color bottomColor = input.color(color.new(color.lime, 0), "底分型颜色", group=GRP_FRAC)
bool showTrendMAs = input.bool(true, "显示趋势均线", group=GRP_TREND)
int fastMaLength = input.int(5, "快线周期", minval=2, maxval=100, group=GRP_TREND)
int slowMaLength = input.int(10, "慢线周期", minval=3, maxval=250, group=GRP_TREND)
color fastMaColor = input.color(color.new(color.orange, 0), "快线颜色", group=GRP_TREND)
color slowMaColor = input.color(color.new(color.blue, 0), "慢线颜色", group=GRP_TREND)
bool showDebugPanel = input.bool(true, "显示诊断面板", group=GRP_DEBUG)

bool isStrictMode = fractalMode == "STRICT"
bool isPrimaryDailyTf = timeframe.isdaily

// 5/10 日线用于观察飞吻、唇吻、湿吻和约一周交易节奏。
// 两条均线只提供当前级别辅助背景，本阶段不得据此删除 detected fractal。
// ta.sma 必须在每根 bar 上执行，保证历史序列计算一致。
float fastTrendMa = ta.sma(close, fastMaLength)
float slowTrendMa = ta.sma(close, slowMaLength)

plot(showTrendMAs ? fastTrendMa : na, title="Fast trend SMA", color=fastMaColor, linewidth=2)
plot(showTrendMAs ? slowTrendMa : na, title="Slow trend SMA", color=slowMaColor, linewidth=2)

// ============================================================
// SECTION 1 — sealed merged bar 历史
// 所有并行数组必须等长。mergedSeq 是持久 ID，不等同于数组下标。
// ============================================================

var array<int> mergedSeqArr      = array.new_int()
var array<int> mergedStartArr    = array.new_int()
var array<int> mergedEndArr      = array.new_int()
var array<float> mergedHighArr   = array.new_float()
var array<float> mergedLowArr    = array.new_float()
var array<int> mergedHighBarArr  = array.new_int()
var array<int> mergedLowBarArr   = array.new_int()
var array<float> mergedOpenArr   = array.new_float()
var array<float> mergedCloseArr  = array.new_float()
var array<int> mergedDirArr      = array.new_int()

// 当前 active merged bar。它未封口，绝不参与分型检测。
var int activeStartBar   = na
var int activeEndBar     = na
var float activeHigh     = na
var float activeLow      = na
var int activeHighBar    = na
var int activeLowBar     = na
var float activeOpen     = na
var float activeClose    = na
var int activeDirection  = DIR_UNKNOWN

var int lastResolvedDirection = DIR_UNKNOWN
var int lastProcessedRawBar = na
var int nextMergedSeq = 0
var bool mergedSealedEvent = false

// 诊断计数只增不减。
var int containMergeCount = 0
var int nonContainSealCount = 0
var int bootstrapDirectionCount = 0
var int invariantErrorCount = 0
var string lastEvent = "等待首根已收盘 K 线"

f_has_containment(float aHigh, float aLow, float bHigh, float bLow) =>
    bool aContainsB = aHigh >= bHigh and aLow <= bLow
    bool bContainsA = bHigh >= aHigh and bLow <= aLow
    aContainsB or bContainsA

f_bootstrap_direction(float aClose, float aHigh, float aLow, float bClose, float bHigh, float bLow) =>
    int result = DIR_UP
    if bClose > aClose
        result := DIR_UP
    else if bClose < aClose
        result := DIR_DOWN
    else
        float aMid = (aHigh + aLow) * 0.5
        float bMid = (bHigh + bLow) * 0.5
        result := bMid < aMid ? DIR_DOWN : DIR_UP
    result

f_merged_arrays_equal() =>
    int n = array.size(mergedSeqArr)
    bool equal = n == array.size(mergedStartArr) and n == array.size(mergedEndArr) and n == array.size(mergedHighArr)
    equal := equal and n == array.size(mergedLowArr) and n == array.size(mergedHighBarArr) and n == array.size(mergedLowBarArr)
    equal := equal and n == array.size(mergedOpenArr) and n == array.size(mergedCloseArr) and n == array.size(mergedDirArr)
    equal

f_trim_merged_history(int maxCount) =>
    while array.size(mergedSeqArr) > maxCount
        array.shift(mergedSeqArr)
        array.shift(mergedStartArr)
        array.shift(mergedEndArr)
        array.shift(mergedHighArr)
        array.shift(mergedLowArr)
        array.shift(mergedHighBarArr)
        array.shift(mergedLowBarArr)
        array.shift(mergedOpenArr)
        array.shift(mergedCloseArr)
        array.shift(mergedDirArr)

// 每次执行先清空瞬时事件；只有封口时才置 true。
mergedSealedEvent := false

bool processRawBar = barstate.isconfirmed and (na(lastProcessedRawBar) or bar_index != lastProcessedRawBar)

if processRawBar
    lastProcessedRawBar := bar_index

    if na(activeHigh)
        activeStartBar  := bar_index
        activeEndBar    := bar_index
        activeHigh      := high
        activeLow       := low
        activeHighBar   := bar_index
        activeLowBar    := bar_index
        activeOpen      := open
        activeClose     := close
        activeDirection := DIR_UNKNOWN
        lastEvent       := "初始化 active merged bar"
    else
        bool hasContain = f_has_containment(activeHigh, activeLow, high, low)

        if hasContain
            int mergeDirection = lastResolvedDirection
            if mergeDirection == DIR_UNKNOWN
                mergeDirection := activeDirection
            if mergeDirection == DIR_UNKNOWN
                mergeDirection := f_bootstrap_direction(activeClose, activeHigh, activeLow, close, high, low)
                bootstrapDirectionCount += 1

            float oldHigh = activeHigh
            float oldLow = activeLow

            if mergeDirection == DIR_UP
                float newHigh = math.max(oldHigh, high)
                float newLow = math.max(oldLow, low)
                if newHigh > oldHigh
                    activeHighBar := bar_index
                if newLow > oldLow
                    activeLowBar := bar_index
                activeHigh := newHigh
                activeLow := newLow
            else
                float newHigh = math.min(oldHigh, high)
                float newLow = math.min(oldLow, low)
                if newHigh < oldHigh
                    activeHighBar := bar_index
                if newLow < oldLow
                    activeLowBar := bar_index
                activeHigh := newHigh
                activeLow := newLow

            activeEndBar := bar_index
            activeClose := close
            activeDirection := mergeDirection
            containMergeCount += 1
            lastEvent := mergeDirection == DIR_UP ? "UP 包含合并" : "DOWN 包含合并"
        else
            bool movesUp = high > activeHigh and low > activeLow
            bool movesDown = high < activeHigh and low < activeLow
            int resolvedDirection = movesUp ? DIR_UP : movesDown ? DIR_DOWN : DIR_UNKNOWN

            if resolvedDirection == DIR_UNKNOWN
                invariantErrorCount += 1
                lastEvent := "错误：非包含关系无确定方向"
            else
                // 封口 active；若它发生过包含合并，保存实际合并方向上下文。
                int sealedDirectionContext = activeDirection == DIR_UNKNOWN ? resolvedDirection : activeDirection
                array.push(mergedSeqArr, nextMergedSeq)
                array.push(mergedStartArr, activeStartBar)
                array.push(mergedEndArr, activeEndBar)
                array.push(mergedHighArr, activeHigh)
                array.push(mergedLowArr, activeLow)
                array.push(mergedHighBarArr, activeHighBar)
                array.push(mergedLowBarArr, activeLowBar)
                array.push(mergedOpenArr, activeOpen)
                array.push(mergedCloseArr, activeClose)
                array.push(mergedDirArr, sealedDirectionContext)

                nextMergedSeq += 1
                lastResolvedDirection := resolvedDirection
                nonContainSealCount += 1
                mergedSealedEvent := true
                lastEvent := resolvedDirection == DIR_UP ? "封口合成 K：方向 UP" : "封口合成 K：方向 DOWN"

                // 当前 raw bar 成为新的 active merged bar。
                activeStartBar  := bar_index
                activeEndBar    := bar_index
                activeHigh      := high
                activeLow       := low
                activeHighBar   := bar_index
                activeLowBar    := bar_index
                activeOpen      := open
                activeClose     := close
                activeDirection := resolvedDirection

                f_trim_merged_history(maxStoredMerged)

if not f_merged_arrays_equal()
    invariantErrorCount += 1
    lastEvent := "错误：merged 并行数组长度不一致"

// ============================================================
// SECTION 2 — detected fractal
// 仅在 MERGED_SEALED 事件后检查最后三根 sealed merged bar。
// ============================================================

var array<int> fractalIdArr       = array.new_int()
var array<int> fractalTypeArr     = array.new_int()
var array<float> fractalPriceArr  = array.new_float()
var array<int> fractalRawBarArr   = array.new_int()
var array<int> fractalSourceSeqArr = array.new_int()
var array<int> fractalConfirmedSeqArr = array.new_int()
var array<label> fractalLabelArr  = array.new<label>()

var int nextFractalId = 0
var int lastCheckedMergedSeq = na
var int topFractalCount = 0
var int bottomFractalCount = 0
var int dualFractalErrorCount = 0

f_fractal_arrays_equal() =>
    int n = array.size(fractalIdArr)
    bool equal = n == array.size(fractalTypeArr) and n == array.size(fractalPriceArr) and n == array.size(fractalRawBarArr)
    equal := equal and n == array.size(fractalSourceSeqArr) and n == array.size(fractalConfirmedSeqArr)
    equal

f_trim_fractal_history(int maxCount) =>
    while array.size(fractalIdArr) > maxCount
        array.shift(fractalIdArr)
        array.shift(fractalTypeArr)
        array.shift(fractalPriceArr)
        array.shift(fractalRawBarArr)
        array.shift(fractalSourceSeqArr)
        array.shift(fractalConfirmedSeqArr)

if mergedSealedEvent
    int mergedCount = array.size(mergedSeqArr)
    if mergedCount >= 3
        int leftIndex = mergedCount - 3
        int midIndex = mergedCount - 2
        int rightIndex = mergedCount - 1
        int midSeq = array.get(mergedSeqArr, midIndex)

        if na(lastCheckedMergedSeq) or midSeq != lastCheckedMergedSeq
            lastCheckedMergedSeq := midSeq

            float leftHigh = array.get(mergedHighArr, leftIndex)
            float leftLow = array.get(mergedLowArr, leftIndex)
            float midHigh = array.get(mergedHighArr, midIndex)
            float midLow = array.get(mergedLowArr, midIndex)
            float rightHigh = array.get(mergedHighArr, rightIndex)
            float rightLow = array.get(mergedLowArr, rightIndex)

            bool looseTop = midHigh > leftHigh and midHigh > rightHigh
            bool looseBottom = midLow < leftLow and midLow < rightLow
            bool strictTop = looseTop and midLow > leftLow and midLow > rightLow
            bool strictBottom = looseBottom and midHigh < leftHigh and midHigh < rightHigh
            bool isTop = isStrictMode ? strictTop : looseTop
            bool isBottom = isStrictMode ? strictBottom : looseBottom

            if isTop and isBottom
                dualFractalErrorCount += 1
                invariantErrorCount += 1
                lastEvent := "错误：同一 merged bar 同时为顶底分型"
            else if isTop or isBottom
                int fractalType = isTop ? FRAC_TOP : FRAC_BOTTOM
                float fractalPrice = isTop ? midHigh : midLow
                int fractalRawBar = isTop ? array.get(mergedHighBarArr, midIndex) : array.get(mergedLowBarArr, midIndex)
                int confirmedSeq = array.get(mergedSeqArr, rightIndex)

                array.push(fractalIdArr, nextFractalId)
                array.push(fractalTypeArr, fractalType)
                array.push(fractalPriceArr, fractalPrice)
                array.push(fractalRawBarArr, fractalRawBar)
                array.push(fractalSourceSeqArr, midSeq)
                array.push(fractalConfirmedSeqArr, confirmedSeq)

                if fractalType == FRAC_TOP
                    topFractalCount += 1
                else
                    bottomFractalCount += 1

                if showFractals
                    string markerText = fractalType == FRAC_TOP ? "顶" : "底"
                    color markerColor = fractalType == FRAC_TOP ? topColor : bottomColor
                    label marker = label.new(fractalRawBar, fractalPrice, markerText,
                         xloc=xloc.bar_index, yloc=yloc.price,
                         style=fractalType == FRAC_TOP ? label.style_label_down : label.style_label_up,
                         color=markerColor, textcolor=color.white, size=size.tiny)
                    array.push(fractalLabelArr, marker)
                    while array.size(fractalLabelArr) > maxVisibleFractal
                        label oldest = array.shift(fractalLabelArr)
                        label.delete(oldest)

                nextFractalId += 1
                lastEvent := fractalType == FRAC_TOP ? "确认 detected TOP" : "确认 detected BOTTOM"
                f_trim_fractal_history(maxStoredFractal)

if not f_fractal_arrays_equal()
    invariantErrorCount += 1
    lastEvent := "错误：fractal 并行数组长度不一致"

// ============================================================
// SECTION 3 — 单例诊断面板
// ============================================================

var table debugTable = na

if showDebugPanel
    if na(debugTable)
        debugTable := table.new(position.top_right, 2, 15,
             bgcolor=color.new(color.black, 72), border_width=1)

    int sealedCount = array.size(mergedSeqArr)
    int storedFractalCount = array.size(fractalIdArr)
    string directionText = lastResolvedDirection == DIR_UP ? "UP" : lastResolvedDirection == DIR_DOWN ? "DOWN" : "UNKNOWN"
    string activeRange = na(activeHigh) ? "—" : str.tostring(activeLow, format.mintick) + " ~ " + str.tostring(activeHigh, format.mintick)
    string invariantText = invariantErrorCount == 0 ? "OK" : "ERROR × " + str.tostring(invariantErrorCount)
    color invariantColor = invariantErrorCount == 0 ? color.lime : color.red
    string tfText = isPrimaryDailyTf ? "日 K（目标周期）" : timeframe.period + "（非主要验收周期）"
    color tfColor = isPrimaryDailyTf ? color.lime : color.orange
    string maRegimeText = na(fastTrendMa) or na(slowTrendMa) ? "数据不足" : fastTrendMa > slowTrendMa ? "BULL：快线 > 慢线" : fastTrendMa < slowTrendMa ? "BEAR：快线 < 慢线" : "NEUTRAL"
    color maRegimeColor = na(fastTrendMa) or na(slowTrendMa) ? color.gray : fastTrendMa > slowTrendMa ? color.lime : fastTrendMa < slowTrendMa ? color.red : color.yellow
    string fastMaText = na(fastTrendMa) ? "—" : str.tostring(fastTrendMa, format.mintick)
    string slowMaText = na(slowTrendMa) ? "—" : str.tostring(slowTrendMa, format.mintick)

    table.cell(debugTable, 0, 0, "Chanlun Phase 1", text_color=color.yellow)
    table.cell(debugTable, 1, 0, fractalMode, text_color=color.yellow)
    table.cell(debugTable, 0, 1, "图表周期", text_color=color.white)
    table.cell(debugTable, 1, 1, tfText, text_color=tfColor)
    table.cell(debugTable, 0, 2, "均线状态", text_color=color.white)
    table.cell(debugTable, 1, 2, maRegimeText, text_color=maRegimeColor)
    table.cell(debugTable, 0, 3, "快线 SMA " + str.tostring(fastMaLength), text_color=fastMaColor)
    table.cell(debugTable, 1, 3, fastMaText, text_color=fastMaColor)
    table.cell(debugTable, 0, 4, "慢线 SMA " + str.tostring(slowMaLength), text_color=slowMaColor)
    table.cell(debugTable, 1, 4, slowMaText, text_color=slowMaColor)
    table.cell(debugTable, 0, 5, "sealed merged", text_color=color.white)
    table.cell(debugTable, 1, 5, str.tostring(sealedCount), text_color=color.white)
    table.cell(debugTable, 0, 6, "active 区间", text_color=color.white)
    table.cell(debugTable, 1, 6, activeRange, text_color=color.aqua)
    table.cell(debugTable, 0, 7, "已解析方向", text_color=color.white)
    table.cell(debugTable, 1, 7, directionText, text_color=color.aqua)
    table.cell(debugTable, 0, 8, "包含合并", text_color=color.white)
    table.cell(debugTable, 1, 8, str.tostring(containMergeCount), text_color=color.white)
    table.cell(debugTable, 0, 9, "封口事件", text_color=color.white)
    table.cell(debugTable, 1, 9, str.tostring(nonContainSealCount), text_color=color.white)
    table.cell(debugTable, 0, 10, "保存分型", text_color=color.white)
    table.cell(debugTable, 1, 10, str.tostring(storedFractalCount), text_color=color.white)
    table.cell(debugTable, 0, 11, "顶 / 底总数", text_color=color.white)
    table.cell(debugTable, 1, 11, str.tostring(topFractalCount) + " / " + str.tostring(bottomFractalCount), text_color=color.white)
    table.cell(debugTable, 0, 12, "Bootstrap 次数", text_color=color.white)
    table.cell(debugTable, 1, 12, str.tostring(bootstrapDirectionCount), text_color=color.white)
    table.cell(debugTable, 0, 13, "不变量", text_color=color.white)
    table.cell(debugTable, 1, 13, invariantText, text_color=invariantColor)
    table.cell(debugTable, 0, 14, "最新事件", text_color=color.white)
    table.cell(debugTable, 1, 14, lastEvent, text_color=color.silver)
else if not na(debugTable)
    table.delete(debugTable)
    debugTable := na

// ============================================================
// 文件结束 — Phase 1 不包含任何笔、线段或中枢逻辑。
// ============================================================
