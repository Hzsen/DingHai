// ============================================================
// Chanlun_DH.pine — 缠论结构工程版 v0.8-phase1-fast-reversal
// Pine Script v6
//
// 规范：Chanlun_requirement.md v0.3，第 14–17、21–22 节
// 当前范围：
//   Phase 0  工程骨架与诊断
//   Phase 1A 收盘后包含处理 / sealed merged bar
//   Phase 1B detected fractal / 底层局部分型
//   Phase 1C ATR + merged span 当前级别分型选择器
//   Phase 1D 快速反转三点桥接 / 小转大代理恢复通道
//   Context  日线 5 SMA / 10 SMA（缠论“吻”辅助，不参与硬过滤）
//
// 故意未实现：笔、tentative 笔、线段、中枢、背驰、多级别。
// 主要验收周期：日 K。其他标准 OHLC 周期允许运行，但不属于本阶段重点。
// ============================================================

//@version=6
indicator("缠论 DH — Phase 1D 快速反转恢复", overlay=true,
     max_lines_count=50, max_labels_count=500, max_boxes_count=10)

// ============================================================
// SECTION 0 — 输入、常量与诊断配置
// ============================================================

const int DIR_UNKNOWN = 0
const int DIR_UP      = 1
const int DIR_DOWN    = -1
const int FRAC_TOP    = 1
const int FRAC_BOTTOM = -1
const int LEVEL_REASON_NONE = 0
const int LEVEL_REASON_NORMAL = 1
const int LEVEL_REASON_FAST_REVERSAL = 2

const string GRP_MERGED = "1. 包含处理"
const string GRP_FRAC   = "2. 底层分型"
const string GRP_LEVEL  = "3. 当前级别筛选"
const string GRP_TREND  = "4. 日线交易均线"

int maxStoredMerged = input.int(5000, "最多保存 sealed 合成 K 线", minval=100, maxval=20000, group=GRP_MERGED)
int maxStoredFractal = input.int(2500, "最多保存 detected fractal", minval=100, maxval=10000, group=GRP_FRAC)
int maxVisibleDetected = input.int(120, "最多显示底层分型", minval=10, maxval=300, group=GRP_FRAC)
string fractalMode = input.string("LOOSE", "分型模式", options=["LOOSE", "STRICT"], group=GRP_FRAC)
bool showDetectedFractals = input.bool(false, "显示底层 detected 分型（调试）", group=GRP_FRAC)
int minLevelMergedSpan = input.int(4, "当前级别最小合成 K 跨度", minval=2, maxval=30, group=GRP_LEVEL)
int levelAtrLength = input.int(14, "ATR 周期", minval=2, maxval=100, group=GRP_LEVEL)
float levelAtrMultiplier = input.float(1.0, "反向确认 ATR 倍数", minval=0.1, maxval=10.0, step=0.1, group=GRP_LEVEL)
bool enableFastReversalRecovery = input.bool(true, "恢复快速 V/N 型反转", group=GRP_LEVEL)
int fastRecoveryMinLegSpan = input.int(2, "快速反转单腿最小合成 K 跨度", minval=1, maxval=10, group=GRP_LEVEL)
float fastRecoveryAtrMultiplier = input.float(0.75, "快速反转单腿最小 ATR 倍数", minval=0.1, maxval=3.0, step=0.05, group=GRP_LEVEL)
float fastRecoverySpeedAtr = input.float(0.30, "快速反转每根合成 K 最小 ATR", minval=0.05, maxval=2.0, step=0.05, group=GRP_LEVEL)
int maxStoredLevelFractal = input.int(1200, "最多保存当前级别分型", minval=50, maxval=5000, group=GRP_LEVEL)
int maxVisibleLevelFractal = input.int(80, "最多显示当前级别分型", minval=10, maxval=250, group=GRP_LEVEL)
bool showLevelFractals = input.bool(true, "显示已确认的当前级别顶底", group=GRP_LEVEL)
color topColor = input.color(color.new(color.red, 0), "顶分型颜色", group=GRP_FRAC)
color bottomColor = input.color(color.new(color.lime, 0), "底分型颜色", group=GRP_FRAC)
bool showTrendMAs = input.bool(true, "显示趋势均线", group=GRP_TREND)
int fastMaLength = input.int(5, "快线周期", minval=2, maxval=100, group=GRP_TREND)
int slowMaLength = input.int(10, "慢线周期", minval=3, maxval=250, group=GRP_TREND)
color fastMaColor = input.color(color.new(color.orange, 0), "快线颜色", group=GRP_TREND)
color slowMaColor = input.color(color.new(color.blue, 0), "慢线颜色", group=GRP_TREND)

bool isStrictMode = fractalMode == "STRICT"

// 5/10 日线用于观察飞吻、唇吻、湿吻和约一周交易节奏。
// 两条均线只提供当前级别辅助背景，本阶段不得据此删除 detected fractal。
// ta.sma 必须在每根 bar 上执行，保证历史序列计算一致。
float fastTrendMa = ta.sma(close, fastMaLength)
float slowTrendMa = ta.sma(close, slowMaLength)
float levelAtr = ta.atr(levelAtrLength)

plot(showTrendMAs ? fastTrendMa : na, title="Fast trend SMA", color=fastMaColor, linewidth=2)
plot(showTrendMAs ? slowTrendMa : na, title="Slow trend SMA", color=slowMaColor, linewidth=2)

// ============================================================
// SECTION 1 — sealed merged bar 历史
// 所有并行数组必须等长。mergedSeq 是持久 ID，不等同于数组下标。
// ============================================================

var array<int> mergedSeqArr      = array.new_int()
var array<int> mergedStartArr    = array.new_int()
var array<int> mergedEndArr      = array.new_int()
var array<float> mergedHighArr   = array.new_float()
var array<float> mergedLowArr    = array.new_float()
var array<int> mergedHighBarArr  = array.new_int()
var array<int> mergedLowBarArr   = array.new_int()
var array<float> mergedOpenArr   = array.new_float()
var array<float> mergedCloseArr  = array.new_float()
var array<int> mergedDirArr      = array.new_int()

// 当前 active merged bar。它未封口，绝不参与分型检测。
var int activeStartBar   = na
var int activeEndBar     = na
var float activeHigh     = na
var float activeLow      = na
var int activeHighBar    = na
var int activeLowBar     = na
var float activeOpen     = na
var float activeClose    = na
var int activeDirection  = DIR_UNKNOWN

var int lastResolvedDirection = DIR_UNKNOWN
var int lastProcessedRawBar = na
var int nextMergedSeq = 0
var bool mergedSealedEvent = false

// 诊断计数只增不减。
var int containMergeCount = 0
var int nonContainSealCount = 0
var int bootstrapDirectionCount = 0
var int invariantErrorCount = 0
var string lastEvent = "等待首根已收盘 K 线"

f_has_containment(float aHigh, float aLow, float bHigh, float bLow) =>
    bool aContainsB = aHigh >= bHigh and aLow <= bLow
    bool bContainsA = bHigh >= aHigh and bLow <= aLow
    aContainsB or bContainsA

f_bootstrap_direction(float aClose, float aHigh, float aLow, float bClose, float bHigh, float bLow) =>
    int result = DIR_UP
    if bClose > aClose
        result := DIR_UP
    else if bClose < aClose
        result := DIR_DOWN
    else
        float aMid = (aHigh + aLow) * 0.5
        float bMid = (bHigh + bLow) * 0.5
        result := bMid < aMid ? DIR_DOWN : DIR_UP
    result

f_merged_arrays_equal() =>
    int n = array.size(mergedSeqArr)
    bool equal = n == array.size(mergedStartArr) and n == array.size(mergedEndArr) and n == array.size(mergedHighArr)
    equal := equal and n == array.size(mergedLowArr) and n == array.size(mergedHighBarArr) and n == array.size(mergedLowBarArr)
    equal := equal and n == array.size(mergedOpenArr) and n == array.size(mergedCloseArr) and n == array.size(mergedDirArr)
    equal

f_trim_merged_history(int maxCount) =>
    while array.size(mergedSeqArr) > maxCount
        array.shift(mergedSeqArr)
        array.shift(mergedStartArr)
        array.shift(mergedEndArr)
        array.shift(mergedHighArr)
        array.shift(mergedLowArr)
        array.shift(mergedHighBarArr)
        array.shift(mergedLowBarArr)
        array.shift(mergedOpenArr)
        array.shift(mergedCloseArr)
        array.shift(mergedDirArr)

// 每次执行先清空瞬时事件；只有封口时才置 true。
mergedSealedEvent := false

bool processRawBar = barstate.isconfirmed and (na(lastProcessedRawBar) or bar_index != lastProcessedRawBar)

if processRawBar
    lastProcessedRawBar := bar_index

    if na(activeHigh)
        activeStartBar  := bar_index
        activeEndBar    := bar_index
        activeHigh      := high
        activeLow       := low
        activeHighBar   := bar_index
        activeLowBar    := bar_index
        activeOpen      := open
        activeClose     := close
        activeDirection := DIR_UNKNOWN
        lastEvent       := "初始化 active merged bar"
    else
        bool hasContain = f_has_containment(activeHigh, activeLow, high, low)

        if hasContain
            int mergeDirection = lastResolvedDirection
            if mergeDirection == DIR_UNKNOWN
                mergeDirection := activeDirection
            if mergeDirection == DIR_UNKNOWN
                mergeDirection := f_bootstrap_direction(activeClose, activeHigh, activeLow, close, high, low)
                bootstrapDirectionCount += 1

            float oldHigh = activeHigh
            float oldLow = activeLow

            if mergeDirection == DIR_UP
                float newHigh = math.max(oldHigh, high)
                float newLow = math.max(oldLow, low)
                if newHigh > oldHigh
                    activeHighBar := bar_index
                if newLow > oldLow
                    activeLowBar := bar_index
                activeHigh := newHigh
                activeLow := newLow
            else
                float newHigh = math.min(oldHigh, high)
                float newLow = math.min(oldLow, low)
                if newHigh < oldHigh
                    activeHighBar := bar_index
                if newLow < oldLow
                    activeLowBar := bar_index
                activeHigh := newHigh
                activeLow := newLow

            activeEndBar := bar_index
            activeClose := close
            activeDirection := mergeDirection
            containMergeCount += 1
            lastEvent := mergeDirection == DIR_UP ? "UP 包含合并" : "DOWN 包含合并"
        else
            bool movesUp = high > activeHigh and low > activeLow
            bool movesDown = high < activeHigh and low < activeLow
            int resolvedDirection = movesUp ? DIR_UP : movesDown ? DIR_DOWN : DIR_UNKNOWN

            if resolvedDirection == DIR_UNKNOWN
                invariantErrorCount += 1
                lastEvent := "错误：非包含关系无确定方向"
            else
                // 封口 active；若它发生过包含合并，保存实际合并方向上下文。
                int sealedDirectionContext = activeDirection == DIR_UNKNOWN ? resolvedDirection : activeDirection
                array.push(mergedSeqArr, nextMergedSeq)
                array.push(mergedStartArr, activeStartBar)
                array.push(mergedEndArr, activeEndBar)
                array.push(mergedHighArr, activeHigh)
                array.push(mergedLowArr, activeLow)
                array.push(mergedHighBarArr, activeHighBar)
                array.push(mergedLowBarArr, activeLowBar)
                array.push(mergedOpenArr, activeOpen)
                array.push(mergedCloseArr, activeClose)
                array.push(mergedDirArr, sealedDirectionContext)

                nextMergedSeq += 1
                lastResolvedDirection := resolvedDirection
                nonContainSealCount += 1
                mergedSealedEvent := true
                lastEvent := resolvedDirection == DIR_UP ? "封口合成 K：方向 UP" : "封口合成 K：方向 DOWN"

                // 当前 raw bar 成为新的 active merged bar。
                activeStartBar  := bar_index
                activeEndBar    := bar_index
                activeHigh      := high
                activeLow       := low
                activeHighBar   := bar_index
                activeLowBar    := bar_index
                activeOpen      := open
                activeClose     := close
                activeDirection := resolvedDirection

                f_trim_merged_history(maxStoredMerged)

if not f_merged_arrays_equal()
    invariantErrorCount += 1
    lastEvent := "错误：merged 并行数组长度不一致"

// ============================================================
// SECTION 2 — detected fractal
// 仅在 MERGED_SEALED 事件后检查最后三根 sealed merged bar。
// ============================================================

var array<int> fractalIdArr       = array.new_int()
var array<int> fractalTypeArr     = array.new_int()
var array<float> fractalPriceArr  = array.new_float()
var array<int> fractalRawBarArr   = array.new_int()
var array<int> fractalSourceSeqArr = array.new_int()
var array<int> fractalConfirmedSeqArr = array.new_int()
var array<float> fractalAtrArr    = array.new_float()
var array<label> fractalLabelArr  = array.new<label>()

var int nextFractalId = 0
var int lastCheckedMergedSeq = na
var int topFractalCount = 0
var int bottomFractalCount = 0
var int dualFractalErrorCount = 0

f_fractal_arrays_equal() =>
    int n = array.size(fractalIdArr)
    bool equal = n == array.size(fractalTypeArr) and n == array.size(fractalPriceArr) and n == array.size(fractalRawBarArr)
    equal := equal and n == array.size(fractalSourceSeqArr) and n == array.size(fractalConfirmedSeqArr) and n == array.size(fractalAtrArr)
    equal

f_trim_fractal_history(int maxCount) =>
    while array.size(fractalIdArr) > maxCount
        array.shift(fractalIdArr)
        array.shift(fractalTypeArr)
        array.shift(fractalPriceArr)
        array.shift(fractalRawBarArr)
        array.shift(fractalSourceSeqArr)
        array.shift(fractalConfirmedSeqArr)
        array.shift(fractalAtrArr)

// ============================================================
// SECTION 3 — 当前级别分型选择器
//
// 数组最后一个元素永远是 tentative extreme；此前元素全部 confirmed。
// 同类型只替换 tentative extreme。出现反向 detected fractal 时，只有
// merged span 和 ATR 反向幅度同时达标，才冻结旧 tentative 并加入新
// tentative。普通门槛失败的反向分型不再直接丢弃，而进入单例 pending
// 缓冲；若后续同型分型令 T-B-T / B-T-B 两腿均满足快速、足幅和总跨度
// 条件，则桥接恢复中间两端。由此不需要全局放松 4 根合成 K 的门槛。
// ============================================================

var array<int> levelFractalIdArr = array.new_int()
var array<int> levelTypeArr = array.new_int()
var array<float> levelPriceArr = array.new_float()
var array<int> levelRawBarArr = array.new_int()
var array<int> levelMergedSeqArr = array.new_int()
var array<float> levelAtrArr = array.new_float()
var array<int> levelSourceFractalIdArr = array.new_int()
var array<bool> levelConfirmedArr = array.new_bool()
var array<int> levelReasonArr = array.new_int()
var array<label> levelLabelArr = array.new<label>()

var int nextLevelFractalId = 0
var int lastProcessedLevelSourceId = na
var int confirmedLevelTopCount = 0
var int confirmedLevelBottomCount = 0
var int fastReversalRecoveryCount = 0

// 普通门槛失败的反向 detected fractal 缓冲区。
// 它不是当前级别端点，只有三点桥接成立后才会写入 level 数组。
var int pendingOppType = na
var float pendingOppPrice = na
var int pendingOppRawBar = na
var int pendingOppMergedSeq = na
var float pendingOppAtr = na
var int pendingOppSourceFractalId = na

f_level_arrays_equal() =>
    int n = array.size(levelFractalIdArr)
    bool equal = n == array.size(levelTypeArr) and n == array.size(levelPriceArr) and n == array.size(levelRawBarArr)
    equal := equal and n == array.size(levelMergedSeqArr) and n == array.size(levelAtrArr)
    equal := equal and n == array.size(levelSourceFractalIdArr) and n == array.size(levelConfirmedArr)
    equal := equal and n == array.size(levelReasonArr)
    equal

f_trim_level_history(int maxCount) =>
    while array.size(levelFractalIdArr) > maxCount
        array.shift(levelFractalIdArr)
        array.shift(levelTypeArr)
        array.shift(levelPriceArr)
        array.shift(levelRawBarArr)
        array.shift(levelMergedSeqArr)
        array.shift(levelAtrArr)
        array.shift(levelSourceFractalIdArr)
        array.shift(levelConfirmedArr)
        array.shift(levelReasonArr)

if mergedSealedEvent
    int mergedCount = array.size(mergedSeqArr)
    if mergedCount >= 3
        int leftIndex = mergedCount - 3
        int midIndex = mergedCount - 2
        int rightIndex = mergedCount - 1
        int midSeq = array.get(mergedSeqArr, midIndex)

        if na(lastCheckedMergedSeq) or midSeq != lastCheckedMergedSeq
            lastCheckedMergedSeq := midSeq

            float leftHigh = array.get(mergedHighArr, leftIndex)
            float leftLow = array.get(mergedLowArr, leftIndex)
            float midHigh = array.get(mergedHighArr, midIndex)
            float midLow = array.get(mergedLowArr, midIndex)
            float rightHigh = array.get(mergedHighArr, rightIndex)
            float rightLow = array.get(mergedLowArr, rightIndex)

            bool looseTop = midHigh > leftHigh and midHigh > rightHigh
            bool looseBottom = midLow < leftLow and midLow < rightLow
            bool strictTop = looseTop and midLow > leftLow and midLow > rightLow
            bool strictBottom = looseBottom and midHigh < leftHigh and midHigh < rightHigh
            bool isTop = isStrictMode ? strictTop : looseTop
            bool isBottom = isStrictMode ? strictBottom : looseBottom

            if isTop and isBottom
                dualFractalErrorCount += 1
                invariantErrorCount += 1
                lastEvent := "错误：同一 merged bar 同时为顶底分型"
            else if isTop or isBottom
                int fractalType = isTop ? FRAC_TOP : FRAC_BOTTOM
                float fractalPrice = isTop ? midHigh : midLow
                int fractalRawBar = isTop ? array.get(mergedHighBarArr, midIndex) : array.get(mergedLowBarArr, midIndex)
                int confirmedSeq = array.get(mergedSeqArr, rightIndex)
                float fractalAtr = levelAtr
                int sourceFractalId = nextFractalId

                array.push(fractalIdArr, sourceFractalId)
                array.push(fractalTypeArr, fractalType)
                array.push(fractalPriceArr, fractalPrice)
                array.push(fractalRawBarArr, fractalRawBar)
                array.push(fractalSourceSeqArr, midSeq)
                array.push(fractalConfirmedSeqArr, confirmedSeq)
                array.push(fractalAtrArr, fractalAtr)

                if fractalType == FRAC_TOP
                    topFractalCount += 1
                else
                    bottomFractalCount += 1

                // 底层局部分型只作为调试层，默认隐藏并使用灰色小标记。
                if showDetectedFractals
                    string markerText = fractalType == FRAC_TOP ? "t" : "b"
                    label marker = label.new(fractalRawBar, fractalPrice, markerText,
                         xloc=xloc.bar_index, yloc=yloc.price,
                         style=fractalType == FRAC_TOP ? label.style_label_down : label.style_label_up,
                         color=color.new(color.gray, 70), textcolor=color.silver, size=size.tiny)
                    array.push(fractalLabelArr, marker)
                    while array.size(fractalLabelArr) > maxVisibleDetected
                        label oldest = array.shift(fractalLabelArr)
                        label.delete(oldest)

                // Phase 1C/1D：将 detected fractal 投入普通选择器与快速反转恢复通道。
                if (na(lastProcessedLevelSourceId) or sourceFractalId != lastProcessedLevelSourceId) and not na(fractalAtr)
                    lastProcessedLevelSourceId := sourceFractalId
                    int levelCount = array.size(levelFractalIdArr)

                    if levelCount == 0
                        array.push(levelFractalIdArr, nextLevelFractalId)
                        array.push(levelTypeArr, fractalType)
                        array.push(levelPriceArr, fractalPrice)
                        array.push(levelRawBarArr, fractalRawBar)
                        array.push(levelMergedSeqArr, midSeq)
                        array.push(levelAtrArr, fractalAtr)
                        array.push(levelSourceFractalIdArr, sourceFractalId)
                        array.push(levelConfirmedArr, false)
                        array.push(levelReasonArr, LEVEL_REASON_NONE)
                        nextLevelFractalId += 1
                    else
                        int lastLevelIndex = levelCount - 1
                        int lastLevelType = array.get(levelTypeArr, lastLevelIndex)
                        float lastLevelPrice = array.get(levelPriceArr, lastLevelIndex)
                        int lastLevelSeq = array.get(levelMergedSeqArr, lastLevelIndex)
                        float lastLevelAtr = array.get(levelAtrArr, lastLevelIndex)

                        if fractalType == lastLevelType
                            // 快速反转桥接：旧 tentative -> pending opposite -> 当前同型 F。
                            // 两条腿都必须有方向、有幅度、有速度，且外层总跨度达到正常门槛。
                            bool recoveredFastReversal = false
                            if enableFastReversalRecovery and not na(pendingOppType) and pendingOppType == -lastLevelType
                                int firstLegSpan = pendingOppMergedSeq - lastLevelSeq
                                int secondLegSpan = midSeq - pendingOppMergedSeq
                                int outerSpan = midSeq - lastLevelSeq
                                float firstLegDistance = math.abs(pendingOppPrice - lastLevelPrice)
                                float secondLegDistance = math.abs(fractalPrice - pendingOppPrice)
                                float firstLegAtr = math.max(lastLevelAtr, pendingOppAtr)
                                float secondLegAtr = math.max(pendingOppAtr, fractalAtr)
                                bool bridgeDirectionValid = lastLevelType == FRAC_TOP ? pendingOppPrice < lastLevelPrice and fractalPrice > pendingOppPrice : pendingOppPrice > lastLevelPrice and fractalPrice < pendingOppPrice
                                bool bridgeSpanValid = firstLegSpan >= fastRecoveryMinLegSpan and secondLegSpan >= fastRecoveryMinLegSpan and outerSpan >= minLevelMergedSpan
                                bool bridgeScaleValid = firstLegDistance >= firstLegAtr * fastRecoveryAtrMultiplier and secondLegDistance >= secondLegAtr * fastRecoveryAtrMultiplier
                                bool bridgeSpeedValid = firstLegDistance / firstLegSpan >= firstLegAtr * fastRecoverySpeedAtr and secondLegDistance / secondLegSpan >= secondLegAtr * fastRecoverySpeedAtr

                                if bridgeDirectionValid and bridgeSpanValid and bridgeScaleValid and bridgeSpeedValid
                                    recoveredFastReversal := true

                                    // 冻结旧 tentative。
                                    array.set(levelConfirmedArr, lastLevelIndex, true)
                                    array.set(levelReasonArr, lastLevelIndex, LEVEL_REASON_FAST_REVERSAL)
                                    if lastLevelType == FRAC_TOP
                                        confirmedLevelTopCount += 1
                                    else
                                        confirmedLevelBottomCount += 1

                                    if showLevelFractals
                                        int oldRawBar = array.get(levelRawBarArr, lastLevelIndex)
                                        string oldText = lastLevelType == FRAC_TOP ? "顶" : "底"
                                        color oldColor = lastLevelType == FRAC_TOP ? topColor : bottomColor
                                        label oldMarker = label.new(oldRawBar, lastLevelPrice, oldText,
                                             xloc=xloc.bar_index, yloc=yloc.price,
                                             style=lastLevelType == FRAC_TOP ? label.style_label_down : label.style_label_up,
                                             color=oldColor, textcolor=color.white, size=size.small,
                                             tooltip="快速反转桥接确认")
                                        array.push(levelLabelArr, oldMarker)

                                    // pending opposite 被后续同型走势证明为有效中间端点。
                                    array.push(levelFractalIdArr, nextLevelFractalId)
                                    array.push(levelTypeArr, pendingOppType)
                                    array.push(levelPriceArr, pendingOppPrice)
                                    array.push(levelRawBarArr, pendingOppRawBar)
                                    array.push(levelMergedSeqArr, pendingOppMergedSeq)
                                    array.push(levelAtrArr, pendingOppAtr)
                                    array.push(levelSourceFractalIdArr, pendingOppSourceFractalId)
                                    array.push(levelConfirmedArr, true)
                                    array.push(levelReasonArr, LEVEL_REASON_FAST_REVERSAL)
                                    nextLevelFractalId += 1

                                    if pendingOppType == FRAC_TOP
                                        confirmedLevelTopCount += 1
                                    else
                                        confirmedLevelBottomCount += 1

                                    if showLevelFractals
                                        string pendingText = pendingOppType == FRAC_TOP ? "顶" : "底"
                                        color pendingColor = pendingOppType == FRAC_TOP ? topColor : bottomColor
                                        label pendingMarker = label.new(pendingOppRawBar, pendingOppPrice, pendingText,
                                             xloc=xloc.bar_index, yloc=yloc.price,
                                             style=pendingOppType == FRAC_TOP ? label.style_label_down : label.style_label_up,
                                             color=pendingColor, textcolor=color.white, size=size.small,
                                             tooltip="快速反转桥接确认")
                                        array.push(levelLabelArr, pendingMarker)

                                    // 当前同型 F 成为新的可变尾端，而不是覆盖旧 tentative。
                                    array.push(levelFractalIdArr, nextLevelFractalId)
                                    array.push(levelTypeArr, fractalType)
                                    array.push(levelPriceArr, fractalPrice)
                                    array.push(levelRawBarArr, fractalRawBar)
                                    array.push(levelMergedSeqArr, midSeq)
                                    array.push(levelAtrArr, fractalAtr)
                                    array.push(levelSourceFractalIdArr, sourceFractalId)
                                    array.push(levelConfirmedArr, false)
                                    array.push(levelReasonArr, LEVEL_REASON_NONE)
                                    nextLevelFractalId += 1
                                    fastReversalRecoveryCount += 1

                                    pendingOppType := na
                                    pendingOppPrice := na
                                    pendingOppRawBar := na
                                    pendingOppMergedSeq := na
                                    pendingOppAtr := na
                                    pendingOppSourceFractalId := na

                                    while array.size(levelLabelArr) > maxVisibleLevelFractal
                                        label oldestRecoveryLabel = array.shift(levelLabelArr)
                                        label.delete(oldestRecoveryLabel)
                                    f_trim_level_history(maxStoredLevelFractal)

                            bool moreExtremeTop = fractalType == FRAC_TOP and fractalPrice > lastLevelPrice
                            bool moreExtremeBottom = fractalType == FRAC_BOTTOM and fractalPrice < lastLevelPrice
                            if not recoveredFastReversal and (moreExtremeTop or moreExtremeBottom)
                                // 最后一个永远是 tentative，因此允许同类型择优替换。
                                array.set(levelPriceArr, lastLevelIndex, fractalPrice)
                                array.set(levelRawBarArr, lastLevelIndex, fractalRawBar)
                                array.set(levelMergedSeqArr, lastLevelIndex, midSeq)
                                array.set(levelAtrArr, lastLevelIndex, fractalAtr)
                                array.set(levelSourceFractalIdArr, lastLevelIndex, sourceFractalId)

                                // tentative 已换锚，旧 pending 不得跨越新锚继续参与桥接。
                                pendingOppType := na
                                pendingOppPrice := na
                                pendingOppRawBar := na
                                pendingOppMergedSeq := na
                                pendingOppAtr := na
                                pendingOppSourceFractalId := na
                        else
                            int mergedSpan = midSeq - lastLevelSeq
                            float reversalDistance = math.abs(fractalPrice - lastLevelPrice)
                            float requiredDistance = math.max(lastLevelAtr, fractalAtr) * levelAtrMultiplier
                            bool directionValid = lastLevelType == FRAC_TOP ? fractalPrice < lastLevelPrice : fractalPrice > lastLevelPrice
                            bool spanValid = mergedSpan >= minLevelMergedSpan
                            bool scaleValid = reversalDistance >= requiredDistance

                            if directionValid and spanValid and scaleValid
                                // 反向运动已足够：冻结旧 tentative，当前 F 成为新的 tentative。
                                array.set(levelConfirmedArr, lastLevelIndex, true)
                                array.set(levelReasonArr, lastLevelIndex, LEVEL_REASON_NORMAL)

                                if lastLevelType == FRAC_TOP
                                    confirmedLevelTopCount += 1
                                else
                                    confirmedLevelBottomCount += 1

                                if showLevelFractals
                                    int confirmedRawBar = array.get(levelRawBarArr, lastLevelIndex)
                                    string levelText = lastLevelType == FRAC_TOP ? "顶" : "底"
                                    color levelColor = lastLevelType == FRAC_TOP ? topColor : bottomColor
                                    label levelMarker = label.new(confirmedRawBar, lastLevelPrice, levelText,
                                         xloc=xloc.bar_index, yloc=yloc.price,
                                         style=lastLevelType == FRAC_TOP ? label.style_label_down : label.style_label_up,
                                         color=levelColor, textcolor=color.white, size=size.small)
                                    array.push(levelLabelArr, levelMarker)
                                    while array.size(levelLabelArr) > maxVisibleLevelFractal
                                        label oldestLevelLabel = array.shift(levelLabelArr)
                                        label.delete(oldestLevelLabel)

                                array.push(levelFractalIdArr, nextLevelFractalId)
                                array.push(levelTypeArr, fractalType)
                                array.push(levelPriceArr, fractalPrice)
                                array.push(levelRawBarArr, fractalRawBar)
                                array.push(levelMergedSeqArr, midSeq)
                                array.push(levelAtrArr, fractalAtr)
                                array.push(levelSourceFractalIdArr, sourceFractalId)
                                array.push(levelConfirmedArr, false)
                                array.push(levelReasonArr, LEVEL_REASON_NONE)
                                nextLevelFractalId += 1

                                pendingOppType := na
                                pendingOppPrice := na
                                pendingOppRawBar := na
                                pendingOppMergedSeq := na
                                pendingOppAtr := na
                                pendingOppSourceFractalId := na
                                f_trim_level_history(maxStoredLevelFractal)
                            else if directionValid
                                // 不合格反向点不再丢失：同类型 pending 只保留更极端者。
                                bool replacePending = na(pendingOppType) or (fractalType == FRAC_TOP and fractalPrice > pendingOppPrice) or (fractalType == FRAC_BOTTOM and fractalPrice < pendingOppPrice)
                                if replacePending
                                    pendingOppType := fractalType
                                    pendingOppPrice := fractalPrice
                                    pendingOppRawBar := fractalRawBar
                                    pendingOppMergedSeq := midSeq
                                    pendingOppAtr := fractalAtr
                                    pendingOppSourceFractalId := sourceFractalId

                nextFractalId += 1
                lastEvent := fractalType == FRAC_TOP ? "确认 detected TOP" : "确认 detected BOTTOM"
                f_trim_fractal_history(maxStoredFractal)

if not f_fractal_arrays_equal()
    invariantErrorCount += 1
    lastEvent := "错误：fractal 并行数组长度不一致"

if not f_level_arrays_equal()
    invariantErrorCount += 1
    lastEvent := "错误：level fractal 并行数组长度不一致"

// ============================================================
// 文件结束 — Phase 1D 仍未实现正式笔、线段、中枢、背驰或真实多级别。
// 快速反转桥接只是当前周期上的小转大代理；未来应由低级别结构确认替代。
// ============================================================
